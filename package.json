        "@vue/tsconfig": "^0.9.1",
        "ajv": "^8.12.0",
        "autoprefixer": "^10.4.23",
        "eslint": "^10.3.0",
        "eslint-plugin-vue": "^10.9.1",
        "postcss": "^8.4.47",
        "prettier": "^3.8.3",
        "sass": "^1.62.1",
        "tailwindcss": "^3.4.11",
        "typescript": "^6.0.3",
        "vite": "^8.0.12",
        "vite-plugin-static-copy": "^4.1.0",
        "vue-tsc": "^3.2.8"
    }
