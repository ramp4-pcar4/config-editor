        "ramp-pcar": "^4.21.0",
        "vue": "^3.5.34",
        "vue-i18n": "^9.13.1",
        "vue-tippy": "^6.6.4",
        "vuedraggable": "next"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.9",
        "@types/node": "^24.1.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vitejs/plugin-vue-jsx": "^5.1.5",
